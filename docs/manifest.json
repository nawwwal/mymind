      "exitCode": 4,
      "hint": "Check the id and try again."
    },
    {
      "code": "RATE_LIMITED",
      "exitCode": 5,
      "hint": "Wait for the retry window or reduce high-cost calls."
    },
    {
      "code": "UPSTREAM_ERROR",
      "exitCode": 64,
      "hint": "The mymind API returned an unexpected error."
    },
    {
      "code": "GENERIC_ERROR",
      "exitCode": 1,
      "hint": "Run with --verbose for more context."
    }
