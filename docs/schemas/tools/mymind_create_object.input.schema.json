{
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "content": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string"
            },
            "body": {}
          },
          "required": [
            "type"
          ],
          "additionalProperties": false
        }
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "flags": {
            "type": "number"
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false
      }
    },
    "spaces": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id"
        ],
        "additionalProperties": false
      }
    },
    "filePath": {
      "type": "string"
    },
    "mimeType": {
      "type": "string"
    },
    "dryRun": {
      "type": "boolean"
    },
    "confirmHighCost": {
      "type": "boolean",
      "const": true
    }
  },
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#"
}
