{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": {}
        }
      ]
    },
    "contentType": {
      "type": "string",
      "enum": [
        "text/markdown",
        "application/prose+json"
      ]
    },
    "dryRun": {
      "type": "boolean"
    },
    "confirmReplace": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "id",
    "content",
    "contentType"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#"
}
