{
  "name": "@nawwal/mymind",
  "version": "1.0.0",
  "description": "Unofficial CLI and MCP bridge for the mymind API (agents-first).",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nawwwal/mymind.git"
  },
  "bugs": {
    "url": "https://github.com/nawwwal/mymind/issues"
  },
  "homepage": "https://github.com/nawwwal/mymind#readme",
  "bin": {
    "mymind": "./dist/cli.js",
    "mymind-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/bin/cli.ts",
    "build": "tsup --entry.index=src/index.ts --entry.cli=src/bin/cli.ts --entry.mcp=src/bin/mcp.ts --format esm --dts --clean --target node22 --out-dir dist --splitting false",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "pack:check": "node scripts/pack-check.mjs",
    "manifest": "tsx scripts/build-manifest.ts",
    "schemas": "tsx scripts/build-json-schemas.ts",
    "output-schemas": "tsx scripts/build-output-schemas.ts",
    "cli-reference": "tsx scripts/build-cli-reference.ts",
    "lint:renames": "node scripts/lint-renames.mjs",
    "lint:api-feedback": "node scripts/lint-api-feedback.mjs",
    "verify": "npm run typecheck && npm run test && npm run build && npm run manifest && npm run schemas && npm run output-schemas && npm run cli-reference && git diff --exit-code docs/manifest.json docs/schemas docs/output-schemas docs/examples docs/cli-reference.md && npm run lint:renames && npm run lint:api-feedback && npm run pack:check",
    "prepublishOnly": "npm run verify"
  },
  "keywords": [
    "mcp",
    "cli",
    "command-line",
    "model-context-protocol",
    "mymind",
    "ai"
  ],
  "author": "nawwal",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.17.5",
    "citty": "^0.2.2",
    "defu": "^6.1.7",
    "figures": "^6.1.0",
    "picocolors": "^1.1.1",
    "terminal-link": "^5.0.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^3.2.4",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
